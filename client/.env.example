# ── API ──────────────────────────────────────────────────────────────────────
# Backend base URL. Leave empty in dev (Vite proxies /api → localhost:8000).
# In production set to your Cloud Run URL or Cloudflare Worker proxy URL.
# Example: https://radianttrust-611643978472.asia-south2.run.app
VITE_API_URL=

# ── Razorpay ─────────────────────────────────────────────────────────────────
# Public key — safe to expose in frontend. Find it in Razorpay Dashboard → Settings → API Keys.
# Use rzp_test_* for test mode, rzp_live_* for production.
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxx
