# ── App ──
APP_NAME=Radiant Education Trust API
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production
FRONTEND_URL=https://radiant.sr931662.workers.dev

# ── Database ──
DATABASE_URL=postgresql+asyncpg://ngo_user:StrongPassword123@localhost:5432/ngo_db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_ECHO=false

# ── Redis ──
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# ── JWT ──
JWT_ACCESS_SECRET=super-secret-access-key-change-me
JWT_REFRESH_SECRET=super-secret-refresh-key-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Razorpay ──
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxx
RAZORPAY_KEY_SECRET=yyyyyyyyyyyyyyyy
RAZORPAY_WEBHOOK_SECRET=zzzzzzzzzzzzzzzz

# ── Email (Resend or SMTP) ──
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_xxxxxxxxxxxxx
EMAIL_FROM=noreply@radianttrust.org
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@radianttrust.org
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=true

# ── Cloudinary ──
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=123456789
CLOUDINARY_API_SECRET=xxxxxxxxxxxx
CLOUDINARY_FOLDER=radiant-trust

# ── Celery ──
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── CORS ──
CORS_ORIGINS=["https://radiant.sr931662.workers.dev","https://radianttrust.sr931662.workers.dev","http://localhost:3000","http://localhost:5173"]

# ── Rate Limiting ──
RATE_LIMIT_GLOBAL=100/minute
RATE_LIMIT_AUTH=5/minute
