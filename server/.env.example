# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=Radiant Education Trust API
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production
FRONTEND_URL=https://radiant-54m.pages.dev

# ── Database ──────────────────────────────────────────────────────────────────
# Supports postgresql://, postgres://, or postgresql+asyncpg:// — all auto-normalised.
# Neon: postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
# Supabase: postgresql://postgres.xxx:pass@aws-0-region.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_ECHO=false

# ── Redis (optional — leave blank to disable caching and Celery) ─────────────
# Upstash Redis: rediss://default:token@endpoint.upstash.io:6379
# Redis Cloud:   redis://default:password@host:port
REDIS_URL=
REDIS_MAX_CONNECTIONS=50

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_ACCESS_SECRET=replace-with-64-char-random-hex
JWT_REFRESH_SECRET=replace-with-another-64-char-random-hex
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Razorpay ──────────────────────────────────────────────────────────────────
# Dashboard → Settings → API Keys
# Use rzp_test_* for test, rzp_live_* for live payments
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=yyyyyyyyyyyyyyyyyyyyyyyy
# Dashboard → Settings → Webhooks → your webhook secret
RAZORPAY_WEBHOOK_SECRET=zzzzzzzzzzzzzzzzzzzzzzzz

# ── Email ─────────────────────────────────────────────────────────────────────
# Provider: "resend" (recommended) or "smtp"
EMAIL_PROVIDER=resend

# Resend (https://resend.com) — get API key from dashboard
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# OR SMTP (e.g. Gmail with App Password)
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=your-16-char-app-password
# SMTP_USE_TLS=true

EMAIL_FROM=noreply@radianttrust.org

# ── Cloudinary ────────────────────────────────────────────────────────────────
# Get from Cloudinary Dashboard → Settings → Access Keys
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLOUDINARY_FOLDER=radiant-trust

# ── Celery (auto-derived from REDIS_URL when blank) ──────────────────────────
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# ── CORS ─────────────────────────────────────────────────────────────────────
# JSON array of allowed origins
CORS_ORIGINS=["https://radiant-54m.pages.dev","https://radianttrust.sr931662.workers.dev","http://localhost:5173"]

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_GLOBAL=200/minute
RATE_LIMIT_AUTH=10/minute
